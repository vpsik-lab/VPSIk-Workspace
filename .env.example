# VPSIk Workspace — Environment Variables
# Copy to .env and customize

# API
API_JWT_SECRET=change-me-in-production
API_USERNAME=admin
API_PASSWORD=admin
API_PORT=8081

# PostgreSQL
POSTGRES_USER=vpsik
POSTGRES_PASSWORD=vpsik
POSTGRES_DB=vpsik

# Gitea
GITEA_URL=http://gitea:3000
GITEA_TOKEN=

# Coolify
COOLIFY_URL=http://coolify:3000
COOLIFY_TOKEN=

# Ollama
OLLAMA_URL=http://ollama:11434

# OpenCode.ai (optional)
OPENCODE_URL=
OPENCODE_TOKEN=

# Restic Backup
RESTIC_REPO=/data/restic
RESTIC_PASSWORD=vpsik

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Dashboard
PUBLIC_API_URL=http://localhost:8081
PUBLIC_OPENWEBUI_URL=http://localhost:3001
