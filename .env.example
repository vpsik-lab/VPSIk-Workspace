# VPSIk Workspace — Environment Variables
# Copy to .env, customize, and place in /opt/workspace/

# ===== Domain =====
WORKSPACE_DOMAIN=workspace.vpsik.com

# ===== Traefik Subdomains =====
TRAEFIK_AUTH_HOST=auth.${WORKSPACE_DOMAIN}
TRAEFIK_GIT_HOST=git.${WORKSPACE_DOMAIN}
TRAEFIK_OLLAMA_HOST=ollama.${WORKSPACE_DOMAIN}
TRAEFIK_CHAT_HOST=chat.${WORKSPACE_DOMAIN}
TRAEFIK_CODE_HOST=code.${WORKSPACE_DOMAIN}
TRAEFIK_DOCS_HOST=docs.${WORKSPACE_DOMAIN}
TRAEFIK_PLANE_HOST=plane.${WORKSPACE_DOMAIN}
TRAEFIK_MATTERMOST_HOST=mattermost.${WORKSPACE_DOMAIN}
TRAEFIK_METRICS_HOST=metrics.${WORKSPACE_DOMAIN}
TRAEFIK_COOLIFY_HOST=coolify.${WORKSPACE_DOMAIN}
TRAEFIK_API_HOST=api.${WORKSPACE_DOMAIN}
TRAEFIK_DASHBOARD_HOST=${VPSIK_DOMAIN}

# ===== Database =====
POSTGRES_USER=workspace
POSTGRES_PASSWORD=workspace
POSTGRES_DB=workspace

# ===== Authentik =====
AUTHENTIK_SECRET_KEY=change-me-in-production
AUTHENTIK_BOOT_PASSWORD=change-me-in-production

# ===== Gitea =====
GITEA_URL=http://gitea:3000
GITEA_TOKEN=

# ===== Coolify =====
COOLIFY_URL=http://coolify:3000
COOLIFY_TOKEN=

# ===== Ollama =====
OLLAMA_URL=http://ollama:11434

# ===== OpenCode.ai (optional) =====
OPENCODE_URL=
OPENCODE_TOKEN=

# ===== Restic Backup =====
RESTIC_REPO=/opt/workspace/backups
RESTIC_PASSWORD=vpsik

# ===== Grafana =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ===== Dashboard =====
PUBLIC_API_URL=http://localhost:8081
PUBLIC_OPENWEBUI_URL=http://openwebui:8080

# ===== Code Server =====
CODESERVER_URL=http://codeserver:8443
CODESERVER_PASSWORD=vpsik

# ===== Plane =====
PLANE_URL=http://plane:8080

# ===== Outline =====
OUTLINE_URL=http://outline:3000
OUTLINE_SECRET_KEY=change-me-in-production

# ===== Mattermost =====
MATTERMOST_URL=http://mattermost:8065

# ===== Cloudflare Tunnel =====
CF_TUNNEL_TOKEN=
